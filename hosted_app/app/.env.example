GOOGLE_GENAI_USE_VERTEXAI=TRUE
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
VECTOR_COLLECTION_ID=your-vector-search-collection
VECTOR_FIELD=embedding
EMBEDDING_MODEL=multimodalembedding@001
RANKING_CONFIG=projects/your-gcp-project-id/locations/global/rankingConfigs/default_ranking_config
SEARCH_TOP_K=100
AGENT_MODEL=gemini-live-2.5-flash-native-audio
